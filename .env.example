PORT=3999
HOST=127.0.0.1
UPSTREAM_URL=http://127.0.0.1:3000

# Default auth behavior forwards the client's Authorization header.
# If set, this key is used as Authorization: Bearer <UPSTREAM_API_KEY> upstream.
# The dashboard only reports configured/not configured and last 4 characters.
AUTH_MODE=forward_client_authorization
UPSTREAM_API_KEY=

# Compression mode: safe, balanced, or aggressive.
# safe is the default and does not strip tools or truncate tool output.
MODE=safe

# Token estimation profile: generic, openai, anthropic, gemini, deepseek, or qwen.
# generic preserves the lightweight fallback estimator.
PROVIDER_PROFILE=generic

# Agent traffic profile: generic, hermes, openclaw, codex, or claude-code.
# Non-generic profiles route tool/function outputs through safer category-aware compression.
AGENT_PROFILE=generic

# Cache-aware mode favors upstream prompt cache stability over maximum compression.
# It disables tools stripping and, unless explicitly enabled, top-level tool schema slimming.
CACHE_AWARE=0

# Optional local deterministic summaries for repeated large tool/function outputs.
# Cache files store summaries only, not raw tool output.
SUMMARY_CACHE=0
SUMMARY_CACHE_DIR=.token-slimmer-cache
SUMMARY_CACHE_MIN_TOKENS=1200

# Schema slimming is enabled by default in all modes.
SLIM_TOOLS=1

# Tool output compression is enabled by default in balanced/aggressive.
# In safe mode this only minifies JSON-looking tool output.
COMPRESS_CONTENT=1

# Tools stripping is only honored in MODE=aggressive and only when explicitly set to 1.
STRIP_TOOLS=0
HEARTBEAT_INTERVAL=3

# Optional request capture for building local benchmark corpora.
# Captures are JSON files with sensitive fields and headers redacted.
CAPTURE_REQUESTS=0
CAPTURE_DIR=captures
